{
  "productName": "Millsonic Player",
  "version": "0.5.7",
  "identifier": "com.millsonic.player",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Millsonic Player",
        "width": 400,
        "height": 620,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": false,
        "center": true,
        "decorations": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "msi",
      "nsis",
      "deb",
      "appimage",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFDOUQ2NjQ5MzhDRDQ3NTUKUldSVlI4MDRTV2FkckI5N3JvbjAyNWZXb0s4ZlpUTkZ5dnVaVjIxb1lmMlNyWEtPUlFxT3YrUkUK",
      "endpoints": [
        "https://apimillsonic.fo.com.uy/api/v1/devices/update/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}